      "id": "Q001",
      "module": "relationship_context",
      "module_id": "relationship_context",
      "title": "关系入口",
      "prompt": "你们当前的关系更接近哪一种？",
      "question_type": "forced_single",
      "selection_mode": "forced_single",
      "required": true,
      "allow_skip": false,
      "modes": ["mvp"],
      "dimensions": ["attachment_commitment_pace", "values_belonging_need"],
      "options": [
        {"id": "plain_chat", "value": "A", "label": "刚认识，还在普通聊天。"},
        {"id": "early_ambiguous", "value": "B", "label": "已经频繁聊天，有一点暧昧。"},
        {"id": "strong_ambiguous", "value": "C", "label": "暧昧明显，但还没有正式确认关系。"},
        {"id": "new_relationship", "value": "D", "label": "刚确认恋爱关系。"},
        {"id": "post_breakup_reconnect", "value": "E", "label": "已经分手，但最近又开始联系。"}
      ],
      "scoring": {
        "base_weight": 1.0,
        "evidence_quality": "context",
        "dimension_effects": {
          "plain_chat": {"attachment_commitment_pace": -8, "values_belonging_need": -2},
          "early_ambiguous": {"attachment_commitment_pace": -4, "values_belonging_need": 2},
          "strong_ambiguous": {"attachment_commitment_pace": 2, "values_belonging_need": 4},
          "new_relationship": {"attachment_commitment_pace": 6, "values_belonging_need": 6},
          "post_breakup_reconnect": {"attachment_commitment_pace": 2, "values_belonging_need": 5}
        }
      },
      "confidence": {"enabled": true, "default": 80, "affects_weight": true},
      "report_tags": ["relationship_entry_context"]
    },
