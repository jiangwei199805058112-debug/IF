      "scoring": {
        "base_weight": 1.0,
        "evidence_quality": "high",
        "dimension_effects": {
          "assume_busy": {"attachment_abandonment_anxiety": -6, "trust_checking_impulse": -6, "emotion_reassurance_need": -4},
          "quiet_discomfort": {"attachment_abandonment_anxiety": 5, "trust_checking_impulse": 0, "emotion_reassurance_need": 4},
          "ask_why": {"attachment_abandonment_anxiety": 7, "trust_checking_impulse": 3, "emotion_reassurance_need": 8},
          "become_cold": {"attachment_abandonment_anxiety": 6, "trust_checking_impulse": 1, "emotion_reassurance_need": 5},
          "check_clues": {"attachment_abandonment_anxiety": 8, "trust_checking_impulse": 9, "emotion_reassurance_need": 6}
