        {"id": "ask_why", "value": "C", "label": "想追问为什么不回。"},
        {"id": "become_cold", "value": "D", "label": "表面不问，但自己开始冷淡。"},
        {"id": "check_clues", "value": "E", "label": "想去看朋友圈、共同好友或其他线索。"}
